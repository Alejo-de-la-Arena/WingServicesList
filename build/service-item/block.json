{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wing/service-item",
  "version": "1.0.0",
  "title": "Wing Service Item",
  "category": "widgets",
  "icon": "id-alt",
  "description": "A single service: image, title and short description.",
  "textdomain": "wing-services-list",
  "parent": [
    "wing/services-list"
  ],
  "supports": {
    "html": false,
    "reusable": false,
    "inserter": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "source": "html",
      "selector": ".wing-service-item__title",
      "default": ""
    },
    "description": {
      "type": "string",
      "source": "html",
      "selector": ".wing-service-item__description",
      "default": ""
    },
    "imageId": {
      "type": "number"
    },
    "imageUrl": {
      "type": "string",
      "default": ""
    },
    "imageAlt": {
      "type": "string",
      "default": ""
    }
  },
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css"
}